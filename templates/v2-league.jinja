{% extends "base_app.jinja" %}

{% block main_body %}
<main class="flex-1 overflow-y-auto md:ml-16 space-y-6 h-screen bg-bg-2 text-text-1 w-fit">
  <div class="fadeUp max-w-7xl mx-auto h-full grid grid-rows-[auto_auto_1fr">
    {{components.header(root)}}
    {{components.hero(root)}}
    <!-- Tabs -->
    <tab-sections class="grid grid-rows-[auto_1fr] overflow-scroll no-scrollbar h-full">
      <nav class="text-sm font-medium text-center border-b border-bg-3 overflow-auto bg-bg-1 pl-6">
        {{components.tab(["Table", "Fixtures", "Player Stats", "Team Stats"], "Table")}}
      </nav>

      <div id="scroll-controller"
        class="w-full h-full rounded-b-md flex overflow-scroll snap-x snap-mandatory scroll-smooth no-scrollbar z-0">

        <!-- Table -->
        <section
          class="rounded-md overflow-auto flex-none w-full h-full bg-bg-2 snap-start snap-always group scroll-smooth no-scrollbar p-3">

          {% for group, table in tables.items() %}

          {% if loop.index == 1 %}

          <div class="flex justify-between p-2 h-fit bg-bg-1 text-sm border-b border-bg-3 rounded-t-xl">
            <span class="text-sm m-2">{{group}}</span>
          </div>
          {% else %}
          <div class="flex justify-between p-2 h-fit bg-bg-1 text-sm border-y border-bg-3">
            <span class="text-sm m-2">{{group}}</span>
          </div>

          {% endif %}


          <div>
            <div class="grid py-4 bg-bg-1 text-sm text-text-6 grid-cols-9 md:grid-cols-15 place-items-center">
              <span class="col-span-1">#</span>
              <span class="col-span-4 md:col-span-7 overflow-hidden justify-self-start">Team</span>
              <span class="col-span-1">P</span>
              <span class="col-span-1 hidden md:block">W</span>
              <span class="col-span-1 hidden md:block">D</span>
              <span class="col-span-1 hidden md:block">L</span>
              <span class="col-span-1">+/-</span>
              <span class="col-span-1">GD</span>
              <span class="col-span-1">PTS</span>
            </div>
            {% for stat in table %}

            <div class="grid bg-bg-1 text-sm grid-cols-9 md:grid-cols-15 place-items-center">
              <div class="col-span-1 justify-self-start flex items-center h-full">
                <div class="mr-3 w-1 h-[80%] {{'bg-brand' if loop.index < 3 else 'bg-none'}} rounded-r-md">
                </div>
                <h2 class="py-1">{{loop.index}}</h2>
              </div>
              <h3
                class="py-1 col-span-4 md:col-span-7 overflow-hidden justify-self-start text-sm my-1 flex items-center">
                <img src="{{root}}assets/{{team_logo[stat.team]}}" class="w-6 mr-2">
                {{stat.team}}
              </h3>
              <h3 class="py-1 col-span-1 text-sm m-2">{{stat.played}}</h3>
              <h3 class="py-1 col-span-1 text-sm m-2 hidden md:block">{{stat.wins}}</h3>
              <h3 class="py-1 col-span-1 text-sm m-2 hidden md:block">{{stat.draws}}</h3>
              <h3 class="py-1 col-span-1 text-sm m-2 hidden md:block">{{stat.loses}}</h3>
              <h3 class="py-1 col-span-1 text-sm m-2">{{stat.goals_scored}} / {{stat.goals_conceded}}</h3>
              <h3 class="py-1 col-span-1 text-sm m-2">{{stat.goals_difference}}</h3>
              <h3 class="py-1 col-span-1 text-sm m-2">{{stat.points}}</h3>
            </div>

            {% endfor %}
          </div>
          {% endfor %}


          <div class="flex justify-between p-2 h-5 bg-bg-1 text-sm rounded-b-xl">
          </div>


          <h3 class="text-xs mt-2 text-text-6 flex items-center gap-3">
            <div class="ml-2 w-2 h-2 bg-brand">
            </div>
            Qualification for Next Round
          </h3>

        </section>

        <!-- Fixtures -->
        <section
          class="overflow-auto flex-none w-full h-full bg-bg-2 snap-start snap-always group scroll-smooth no-scrollbar p-3 gap-6">

          {% macro fixture(match) %}
          <drop-down-toggle>
            <div class="w-full h-4">
            </div>
            <div dropdowntoggle class="rounded-b-xl w-full h-fit bg-bg-1 pt-3 border-b border-bg-3">
              <div
                class="grid grid-cols-[35%_9%_12%_9%_35%] md:grid-cols-[38%_7%_10%_7%_38%] h-fit bg-bg-1 text-xs md:text-sm rounded-xl place-items-center">

                <h1 class="col-span-1 justify-self-end font-semibold min-w-0">{{match.home}}
                </h1>
                <img src="{{root}}assets/{{team_logo[match.home]}}" class="w-6">

                <span class="text-sm">
                  {% if match.events %}
                  
                  {{match.map.goal | selectattr("side", "equalto", "h") | list | length}} -
                  {{match.map.goal |
                  selectattr("side", "equalto", "a") | list | length}}
                  {% else %}
                  -
                  {% endif %}

                </span>

                <img src="{{root}}assets/{{team_logo[match.away]}}" class="w-6">
                <h1 class="col-span-1 justify-self-start font-semibold">{{match.away}}
                </h1>
                
              </div>
              <div class="grid grid-cols-[minmax(0,1fr)_25%_minmax(0,1fr)] md:grid-cols-[minmax(0,auto)_20%_minmax(0,auto)] h-8 text-xs p-2 place-items-center">
                <div class="col-span-1 w-4 h-4 justify-self-start">
                </div>
                <div class="col-span-1 text-center text-text-6">
                  {% if match.events %}
                    FULL TIME
                  {% else %}
                    {{match.date.strftime("%H : %M")}}
                  {% endif %}
                  </div>
                <div class="col-span-1 w-4 h-4 justify-self-end">
                  <div dropdownicon class="h-fit">
                    <iconify-icon icon="icon-park-solid:down-one" class="w-4 h-4"></iconify-icon>
                  </div>
                </div>
              </div>
            </div>


            <div dropdown class="bg-bg-alt-1 hidden rounded-xl h-fit border-b border-bg-3">
              {% for event in match.events %}

              {% if event.name == "goal" %}
              <div class="flex {{ 'flex-row-reverse' if event.event.side == 'a' else ''}} items-center gap-2 p-2 h-fit bg-bg-1 text-sm rounded-xl">
                <div class="hidden md:block w-10 lg:w-30">
                </div>
                <iconify-icon icon="fluent-emoji-high-contrast:soccer-ball" width="100%" height="100%" class="w-6 h-6"></iconify-icon>
                <div class="flex flex-col m-2">
                  <h3 class="text-sm">
                  {{event.event.scorer}}
                  <span></span>
                  {{'(Own Goal)' if event.event.is_own_goal else ''}}
                  </h3>
                  {% if event.event.assist %}
                  <h3 class="text-sm text-text-6">assist: {{event.event.assist}}</h3>
                  {% endif %}
                </div>
              </div>
              {% elif event.name == "red_card"%}
              
              <div class="flex {{ 'flex-row-reverse' if event.event.side == 'a' else ''}} items-center gap-2 p-2 h-fit bg-bg-1 text-sm rounded-xl">
                <div class="hidden md:block w-10 lg:w-30">
                </div>
                <div class="w-4 h-6 bg-red-500"></div>
                <div class="flex flex-col m-2">
                  <h3 class="text-sm">{{event.event.player}}</h3>
                </div>
              </div>
              {% elif event.name == "yellow_card"%}
              
              <div class="flex {{ 'flex-row-reverse' if event.event.side == 'a' else ''}} items-center gap-2 p-2 h-fit bg-bg-1 text-sm rounded-xl">
                <div class="hidden md:block w-10 lg:w-30">
                </div>
                <div class="w-4 h-6 bg-yellow-500"></div>
                <div class="flex flex-col m-2">
                  <h3 class="text-sm">{{event.event.player}}</h3>
                </div>
              </div>
              {# {% elif event.name == "penalty_shootout"%}
              
              <div class="flex {{ 'flex-row-reverse' if event.event.side == 'a' else ''}} items-center gap-2 p-2 h-fit bg-bg-1 text-sm rounded-xl">
                <div class="hidden md:block w-10 lg:w-30">
                </div>
                <iconify-icon icon="fluent-emoji-high-contrast:soccer-ball" width="100%" height="100%" class="w-6 h-6"></iconify-icon>
                <div class="flex flex-col m-2">
                  <h3 class="text-sm">{{event.event.scorer}}</h3>
                  {% if event.event.assist %}
                  <h3 class="text-sm text-text-6">assist: {{event.event.assist}}</h3>
                  {% endif %}
                </div>
              </div> #}
              {% elif event.name == "sub"%}
              
              <div class="flex {{ 'flex-row-reverse' if event.event.side == 'a' else ''}} items-center gap-2 p-2 h-fit bg-bg-1 text-sm rounded-xl">
                <div class="hidden md:block w-10 lg:w-30">
                </div>
                <img src="{{root}}/assets/sub.svg" class="w-6 h-6">
                <div class="flex flex-col m-2">
                  <h3 class="text-sm">in: {{event.event.in}}</h3>
                  <h3 class="text-sm text-text-6">out: {{event.event.out}}</h3>
                </div>
              </div>
              {% endif %}
              {% endfor %}
            </div>
          </drop-down-toggle>
          {% endmacro %}

          {% macro matchday(day) %}
          <div dropdowntoggle class="rounded-t-xl flex justify-between p-2 w-full h-fit bg-bg-alt-1 hover:bg-bg-alt-2 border border-bg-3">
            <div class="text-sm m-2">
              <span>{{day}}</span>
            </div>
            <div dropdownicon class="p-2 rotate-180">
              <iconify-icon icon="icon-park-solid:down-one" width="100%" height="100%"
                class="w-4 h-4 group-data-[theme=dark]:hidden group-data-[theme=light]:block"></iconify-icon>
            </div>
          </div>
          {% endmacro %}

          <div class="bg-bg-1 flex flex-col h-fit rounded-xl mb-4">
            <drop-down-toggle>
              {{matchday("Pre Season: June 28 2026")}}

              <div dropdown class="rounded-b-xl h-fit divide divide-y divide-bg-3 bg-bg-2">

                {% for match in preseason %}
                {{fixture(match)}}
                {% endfor %}

              </div>
            </drop-down-toggle>
          </div>

          {% for key, match in fixtures.items() %}
          <div class="bg-bg-1 flex flex-col h-fit rounded-xl mb-4">
            <drop-down-toggle>
              {{matchday(key)}}

              <div dropdown class="rounded-b-xl h-fit divide divide-y divide-bg-3 bg-bg-2">

                {% for fix in match %}
                {{fixture(fix)}}
                {% endfor %}
              </div>
            </drop-down-toggle>
          </div>
          {% endfor %}

        </section>

        <!-- Player Stats -->
        <section
          class="overflow-auto flex-none w-full h-full bg-bg-2 snap-start snap-always group scroll-smooth no-scrollbar">
