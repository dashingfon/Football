
{% macro header(root) %}
            <nav class="sticky top-0 left-0 w-full justify-between p-3 flex items-center">
                <div class="flex">
                    <a href="{{root}}">
                        <img src="{{root}}/assets/favicon.ico" class="w-6 h-6 md:hidden mr-4" />
                    </a>
                    <a class="flex items-center gap-3" href="{{root}}/leagues.html">
                        <span>/ </span>
                        <span class="text-sm">Leagues</span>
                    </a>
                </div>
                
                <div>
                    <mode-toggle-button>
                        <button
                            class="p-1 bg-bg-3 hover:bg-bg-1 text-text-2 rounded-md border border-bg-1"
                            mode-toggle
                        >
                            <iconify-icon
                            icon="meteocons:starry-night-fill"
                            width="100%"
                            height="100%"
                            class="w-8 h-8 group-data-[theme=dark]/body:hidden group-data-[theme=light]/body:block"
                            ></iconify-icon>

                            <iconify-icon
                            icon="meteocons:clear-day-fill"
                            width="100%"
                            height="100%"
                            class="w-8 h-8 group-data-[theme=dark]/body:block group-data-[theme=light]/body:hidden"
                            ></iconify-icon>
                        </button>
                    </mode-toggle-button>
                </div>
            </nav>
{% endmacro %}

