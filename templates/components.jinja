
{% macro header(root) %}
            <nav class="h-fit top-0 left-0 w-full justify-between p-3 flex items-center">
                <div class="flex">
                    <a href="{{root}}" class="flex items-center">
                        <img src="{{root}}/assets/favicon.ico" class="w-6 h-6 md:hidden mr-3" />
                    </a>
                    <a class="flex justify-center gap-3 py-2 px-3 bg-bg-3 hover:bg-bg-1 rounded-xl text-xs" href="{{root}}/leagues.html">
                        <span class="text-sm">Leagues</span>
                    </a>
                </div>
                
                <div>
                    <mode-toggle-button>
                        <button
                            class="p-1 bg-bg-3 hover:bg-bg-1 text-text-2 rounded-md border border-bg-1"
                            mode-toggle
                        >
                            <iconify-icon
                            icon="meteocons:starry-night-fill"
                            width="100%"
                            height="100%"
                            class="w-8 h-8 group-data-[theme=dark]/body:hidden group-data-[theme=light]/body:block"
                            ></iconify-icon>

                            <iconify-icon
                            icon="meteocons:clear-day-fill"
                            width="100%"
                            height="100%"
                            class="w-8 h-8 group-data-[theme=dark]/body:block group-data-[theme=light]/body:hidden"
                            ></iconify-icon>
                        </button>
                    </mode-toggle-button>
                </div>
            </nav>
{% endmacro %}

{% macro hero() %}
            <section class="flex flex-col md:flex-row bg-bg-1 pt-8 pb-5 md:pb-10 xl:rounded-t-xl border-t border-bg-3">
                <div class="justify-start flex w-full">
                    <img src="{{root}}assets/gyfa.png" class="h-15 pl-6" alt="">
                    <div class="pl-4">
                        <h1 class="text-2xl font-bold">Rep Your Club</h1>
                        <h3 class="text-lg">GYFA</h3>
                    </div>
                </div>

                <div class="flex justify-end pr-6">
                    <button class="flex justify-center gap-3 py-2 px-3 bg-bg-2 rounded-xl text-xs h-fit">
                        <h1 class="text-sm">July / August 2026</h1>
                    </button>

                </div>
            </section>
{% endmacro %}

{% macro tab(tabs, active) %}
            <ul class="flex overflow-x-auto no-scrollbar">
                {% for tab_item in tabs %}
                    <li class="tab group" data-index="{{loop.index - 1}}" 
                    data-active="{{ 'true' if tab_item == active else 'false' }}"

                        ><button
                        class="inline-block p-2 group-data-[active=true]:border-b-4 group-data-[active=false]:border-b-2 group-data-[active=false]:border-transparent 
                        group-data-[active=false]:text-text-6 group-data-[active=true]:border-brand rounded-t-base hover:bg-bg-3"
                        >
                        {{tab_item}}
                        </button>
                    </li>
                {% endfor %}
            </ul>
{% endmacro %}

