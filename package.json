{
  "name": "fotclan",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build:css": "npx @tailwindcss/cli -i ./frontend/assets/index.css -o ./frontend/assets/output.css",
    "build:css-prod": "npx @tailwindcss/cli -i ./frontend/assets/index.css -o ./frontend/assets/output.css --minify",
    "build:css-watch": "npx @tailwindcss/cli -i ./frontend/assets/index.css -o ./frontend/assets/output.css --watch",
    "build": "vite build --mode development && npx @tailwindcss/cli -i ./frontend/assets/index.css -o ./frontend/assets/output.css",
    "build:watch": "vite build --watch",
    "build:prod": "vite build --mode production && npx @tailwindcss/cli -i ./frontend/assets/index.css -o ./frontend/assets/output.css --minify"
  },
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@tailwindcss/cli": "^4.1.11",
    "tailwindcss": "^4.1.11",
    "viem": "^2.47.12"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.11",
    "vite": "^7.0.0"
  }
}
